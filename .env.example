# TSUNAGI Funding — Oracle Configuration
# Copy to .env.local and fill in values.

# Oracle mode: "mock" for demo data, "live" for Charli3 on-chain feed
NEXT_PUBLIC_ORACLE_MODE=mock

# Oracle feed name
NEXT_PUBLIC_ORACLE_FEED=ADA/USD

# Kupo endpoint (for querying oracle UTxOs)
NEXT_PUBLIC_KUPO_URL=

# Ogmios endpoint (reserved for future use)
NEXT_PUBLIC_OGMIOS_URL=

# Charli3 oracle address and policy ID on preprod
NEXT_PUBLIC_CHARLI3_ADDRESS=
NEXT_PUBLIC_CHARLI3_POLICY_ID=

# App
NEXT_PUBLIC_NETWORK=preprod
